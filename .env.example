# Arie AI — Environment Variables
# Copy this file to .env and fill in your values before running or building.
# NEVER commit .env to git.

# ── Microsoft OAuth (Azure AD) ─────────────────────────────────
# Register at: https://portal.azure.com → Azure AD → App registrations
# Redirect URI: http://localhost:3000/auth/microsoft/callback
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=

# ── Google OAuth ───────────────────────────────────────────────
# Register at: https://console.cloud.google.com → Credentials → OAuth 2.0
# Redirect URI: http://localhost:3000/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── macOS Code Signing & Notarization (build only) ────────────
# Required to distribute outside the App Store without Gatekeeper warnings.
# Leave blank for unsigned local builds.
APPLE_ID=
APPLE_APP_SPECIFIC_PASSWORD=
APPLE_TEAM_ID=

# ── Windows Code Signing (build only) ─────────────────────────
# Optional — without this Windows Defender will warn on first launch.
# CSC_LINK=path/to/certificate.p12
# CSC_KEY_PASSWORD=

# ── Auto-updater (GitHub Releases) ────────────────────────────
# Required for automatic updates via electron-updater.
# Create a GitHub personal access token with repo scope.
# GH_TOKEN=
