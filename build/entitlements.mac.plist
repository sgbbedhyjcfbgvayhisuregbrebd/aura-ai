<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <!-- Allow JIT compilation (required by Electron/V8) -->
  <key>com.apple.security.cs.allow-jit</key>
  <true/>
  <!-- Allow unsigned executable memory (Electron needs this) -->
  <key>com.apple.security.cs.allow-unsigned-executable-memory</key>
  <true/>
  <!-- Disable library validation so native modules load -->
  <key>com.apple.security.cs.disable-library-validation</key>
  <true/>
  <!-- Network access — needed for API calls -->
  <key>com.apple.security.network.client</key>
  <true/>
  <!-- Keychain access — for encrypted secret storage -->
  <key>com.apple.security.keychain-access-groups</key>
  <array>
    <string>$(AppIdentifierPrefix)ai.arie.app</string>
  </array>
</dict>
</plist>
